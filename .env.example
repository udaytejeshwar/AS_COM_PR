# Excel / Microsoft 365 (Power Automate HTTP trigger)
# Preferred: set one URL used by both forms
VITE_EXCEL_SUBMISSION_URL=https://prod-00.westus.logic.azure.com:443/workflows/YOUR_FLOW_ID/triggers/manual/paths/invoke?api-version=2016-10-01&sp=YOUR_SIGNATURE

# Optional: set separate URLs per form if you use separate flows
# VITE_EXCEL_QUOTE_SUBMISSION_URL=https://prod-00.westus.logic.azure.com:443/workflows/YOUR_QUOTE_FLOW_ID/triggers/manual/paths/invoke?api-version=2016-10-01&sp=YOUR_SIGNATURE
# VITE_EXCEL_CONTACT_SUBMISSION_URL=https://prod-00.westus.logic.azure.com:443/workflows/YOUR_CONTACT_FLOW_ID/triggers/manual/paths/invoke?api-version=2016-10-01&sp=YOUR_SIGNATURE

# Backward-compatible Google Sheets endpoint (fallback if Excel vars are not set)
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ImageKit
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/arkspindles

# Bump this value after replacing ImageKit assets with the same filename.
# Example values: 2026-06-07, 20260607-1, product-refresh-2
VITE_IMAGEKIT_ASSET_VERSION=20260607-1
